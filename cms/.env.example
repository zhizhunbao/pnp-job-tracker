# cms 环境变量(cp .env.example .env 填值;.env 不进 git)。生产另有 docker/.env(域名/库密码/SEED_TOKEN)。

DATABASE_URI=postgresql://pnp:pnp@localhost:5432/pnp   # 本地 dev 走宿主 5432;容器内由 compose 覆盖
PAYLOAD_SECRET=                    # 强随机(openssl rand -hex 24);生产必须换新值

# ── AI 顾问(E2-03 后二选一) ──
OLLAMA_URL=http://192.168.1.150:11434   # 本地 dev:家里 Ollama
OLLAMA_MODEL=qwen3:4b
# LLM_PROVIDER=anthropic            # 线上:云 LLM(E2-03)
# ANTHROPIC_API_KEY=

# ── R3 部署(E2-01;不设=seed 读本地 data/mart,本地 dev 模式) ──
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_KEY=              # service_role key(seed 从 Storage 拉 mart;worker 上传同用)

# ── 安全/限流(E2-02;不设=本地 dev 放行/用默认值) ──
# SEED_TOKEN=                       # 设置后 /seed 必须带 x-seed-token(生产由 docker/.env 注入)
# ADVISOR_IP_DAILY=40               # advisor 每 IP 日限
# ADVISOR_DAILY_CAP=1000            # advisor 全局日上限(LLM 成本兜底)
# JOBTEXT_IP_DAILY=200              # jobtext 每 IP 日限

# ── 分层(E3-05;默认值见 lib/plan.ts,不设即用默认) ──
# FREE_ADVISOR_TRIES=8             # 免费登录用户 advisor 每日试用次数(超 402)
# FREE_JOBTEXT_TRIES=20            # 免费登录用户 JD 摘录每日试用次数
# PRO_ADVISOR_DAILY=200            # Pro 个人日上限(防滥用)
# FREE_MATCH_JOBS_PER_DAY=10       # 免费档案匹配:每日前 N 岗

# ── 支付(E3-03/04,时长包) ──
# STRIPE_SECRET_KEY=                # sk_test_*(切 live 见 E3-06)
# STRIPE_WEBHOOK_SECRET=            # whsec_*(Dashboard webhook endpoint / stripe listen 给出)
# STRIPE_PRICE_30D=                 # price_*(Dashboard 建 one-time Price:Pro 30 天)
# STRIPE_PRICE_90D=                 # price_*(同上:Pro 90 天)
# STRIPE_WECHAT_PAY=                # Dashboard 确认 wechat_pay 开通后设 1(默认关)
# NEXT_PUBLIC_SITE_URL=https://jobs.example.com
# NEXT_PUBLIC_UMAMI_SRC=https://cloud.umami.is/script.js   # E7-02:umami cloud(免费档);不设=不注入
# NEXT_PUBLIC_UMAMI_ID=                                    # umami website id
# NEXT_PUBLIC_PRICE_DISPLAY=CA$19,CA$39   # 定价页展示价(30天,90天;与 Stripe Price 一致)
# NEXT_PUBLIC_SUPPORT_EMAIL=          # 法务页公开邮箱(默认 wangsansi9527@gmail.com,定域名后换)
