# cms 环境变量(cp .env.example .env 填值;.env 不进 git)。生产另有 docker/.env(域名/库密码/SEED_TOKEN)。

DATABASE_URI=postgresql://pnp:pnp@localhost:5432/pnp   # 本地 dev 走宿主 5432;容器内由 compose 覆盖
PAYLOAD_SECRET=                    # 强随机(openssl rand -hex 24);生产必须换新值

# ── AI 顾问(E2-03 后二选一) ──
OLLAMA_URL=http://192.168.1.150:11434   # 本地 dev:家里 Ollama
OLLAMA_MODEL=qwen3:4b
# LLM_PROVIDER=anthropic            # 线上:云 LLM(E2-03)
# ANTHROPIC_API_KEY=

# ── 安全/限流(E2-02;不设=本地 dev 放行/用默认值) ──
# SEED_TOKEN=                       # 设置后 /seed 必须带 x-seed-token(生产由 docker/.env 注入)
# ADVISOR_IP_DAILY=40               # advisor 每 IP 日限
# ADVISOR_DAILY_CAP=1000            # advisor 全局日上限(LLM 成本兜底)
# JOBTEXT_IP_DAILY=200              # jobtext 每 IP 日限

# ── 支付(E3-03/04,时长包) ──
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_30D=
# STRIPE_PRICE_90D=
# NEXT_PUBLIC_SITE_URL=https://jobs.example.com
# NEXT_PUBLIC_PRICE_DISPLAY=
