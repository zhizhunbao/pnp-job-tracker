# 生产部署配置(E2-01/02):cp .env.example .env 并填值;compose 在本目录自动读取。.env 不进 git。
# 强随机值生成:openssl rand -hex 24

SITE_DOMAIN=jobs.example.com      # 正式域名(A 记录指 VPS)
POSTGRES_PASSWORD=                # 库密码(首次 up 初始化进 pgdata 卷)
SEED_TOKEN=                       # seed 端点鉴权(cms 校验,build 容器带上)
ANTHROPIC_API_KEY=                # news 容器:新闻翻译兜底(NEWS_LLM_BASE 未设时用;空=只抓原文不翻译)
NEWS_LLM_BASE=                    # 局域网 Ollama(如 http://192.168.1.150:11434)——设了翻译走本地零 API 费
NEWS_LLM_MODEL=qwen3.6:latest     # 本地翻译模型(实测中/韩编号协议全守)
HEALTHCHECK_PING_NEWS=            # healthchecks.io 的 news 源 ping URL(可选)
