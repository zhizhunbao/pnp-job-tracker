# ── data/ 衍生文件(可由 ETL 重新生成,不入 git;源 JSON 仍跟踪)──
# 源轮次完成标记(auto_update 用于「先抓后灌」触发)
/data/.rounds/
# 08→09 评分中间产物 + audit 产出(processed 下,可重算)
/data/processed/all-scored.json
/data/processed/audit-flags.json
# 人读导出视图(csv)
/data/**/*.csv
# 公司名录导出视图(保留 .json)
# ATS 名录导出视图 .md(.json 名录跟踪)
/data/raw/ats/*.md
# ATS 公司岗位详情 .md(scraped,可重抓;profile/jobs.json 跟踪)
/data/processed/ats/**/jobs/*.md
# 抓取日志与原始 html 缓存(policy 正文 .md 仍跟踪)
/data/**/*.log
/data/raw/policy/**/html_cache/

# raw/<源>/ 原始 HTML 快照及衍生(每日可重抓;维护表在 reference/ 跟踪)
/data/raw/jobbank/
/data/raw/oinp/
/data/raw/aaip/
# processed 累积 store(从快照重建)+ mart 集市层(09 衍生)
/data/processed/jobbank/
/data/mart/
# GeoNames 源(可从 download.geonames.org/export/zip/CA.zip 重下;衍生表 fsa/fsa-districts.json 跟踪)
/data/raw/fsa/CA.txt
# ESDC 工资源 CSV(可从 open.canada.ca 重下;衍生表 wages/wages.json 跟踪)
/data/raw/wages/*.csv
