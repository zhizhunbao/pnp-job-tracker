# ── data/ 衍生文件(可由 ETL 重新生成,不入 git;源 JSON 仍跟踪)──
# load 阶段计算产出(all-scored.json 等,08_score 可重算)
/data/output/
# 人读导出视图(csv)
/data/**/*.csv
# 公司名录导出视图(保留 .json)
# ATS 名录导出视图 .md(.json 名录跟踪)
/data/raw/ats/*.md
# ATS 公司岗位详情 .md(scraped,可重抓;profile/jobs.json 跟踪)
/data/processed/ats/**/jobs/*.md
# 抓取日志与原始 html 缓存(policy 正文 .md 仍跟踪)
/data/**/*.log
/data/raw/reference/policy/**/html_cache/

# raw/<源>/ 原始 HTML 快照及衍生(每日可重抓;维护表在 reference/ 跟踪)
/data/raw/jobbank/
/data/raw/oinp/
/data/raw/aaip/
# processed 累积 store(从快照重建)+ mart 集市层(09 衍生)
/data/processed/jobbank/
/data/mart/
# GeoNames 源(可从 download.geonames.org/export/zip/CA.zip 重下;衍生表 fsa-districts.json 跟踪)
/data/raw/reference/geonames/
# ESDC 工资源 CSV(可从 open.canada.ca 重下;衍生表 wages.json 跟踪)
/data/raw/reference/wages/*.csv
